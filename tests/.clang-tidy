# Applies when running clang-tidy on paths under tests/ (nearest .clang-tidy wins).
Checks: >
  modernize-*,
  performance-*,
  readability-*,
  bugprone-*,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-do-while,
  -readability-identifier-length,
  -readability-magic-numbers

WarningsAsErrors: ''
HeaderFilterRegex: '.*'
